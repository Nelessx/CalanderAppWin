<local:WidgetBaseWindow
    x:Class="NepaliCalendar.App.WidgetSmallWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NepaliCalendar.App"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Border
        x:Name="RootBorder"
        Padding="6"
        Background="#F6F9FF"
        BorderBrush="#E3EBF7"
        BorderThickness="1"
        CornerRadius="16"
        MouseLeftButtonDown="RootBorder_MouseLeftButtonDown"
        MouseLeftButtonUp="RootBorder_MouseLeftButtonUp"
        MouseMove="RootBorder_MouseMove">

        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Click="OpenAppMenuItem_Click" Header="Open App" />
                <Separator Style="{StaticResource ModernSeparatorStyle}" />
                <MenuItem Header="Widget Size">
                    <MenuItem
                        x:Name="SmallSizeMenuItem"
                        Click="SwitchToSmallMenuItem_Click"
                        Header="Small"
                        IsCheckable="True" />
                    <MenuItem
                        x:Name="MediumSizeMenuItem"
                        Click="SwitchToMediumMenuItem_Click"
                        Header="Medium"
                        IsCheckable="True" />
                    <MenuItem
                        x:Name="LargeSizeMenuItem"
                        Click="SwitchToLargeMenuItem_Click"
                        Header="Large"
                        IsCheckable="True" />
                </MenuItem>
                <Separator Style="{StaticResource ModernSeparatorStyle}" />
                <MenuItem Click="CloseMenuItem_Click" Header="Close Widget" />
            </ContextMenu>
        </Border.ContextMenu>

        <Grid Width="74" Height="90">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="SmallWeekdayText"
                Grid.Row="0"
                HorizontalAlignment="Center"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#7A8FC0"
                TextAlignment="Center" />

            <Border
                Grid.Row="1"
                Height="1"
                Margin="0,1,0,0"
                Background="#E7EEF8" />

            <TextBlock
                x:Name="SmallDayText"
                Grid.Row="2"
                Margin="0,-6,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                FontSize="44"
                FontWeight="Bold"
                Foreground="#0B1B45"
                TextAlignment="Center" />

            <StackPanel
                Grid.Row="3"
                Margin="0,1,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <Ellipse
                    Width="5"
                    Height="5"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Fill="#7A8FC0" />
                <TextBlock
                    x:Name="SmallMonthText"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="#7A8FC0" />
                <Ellipse
                    Width="5"
                    Height="5"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    Fill="#7A8FC0" />
            </StackPanel>
        </Grid>
    </Border>
</local:WidgetBaseWindow>