<Window
    x:Class="NepaliCalendar.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NepaliCalendar.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Nepali Calendar"
    MinWidth="900"
    MinHeight="600"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <local:BooleanToBrushConverter x:Key="BoolToBrush" />
        <local:EmptyCellToBrushConverter x:Key="EmptyCellTextBrush" />
        <local:TodayBorderConverter x:Key="TodayBorderBrush" />
    </Window.Resources>

    <!--  Viewbox makes UI scale proportionally  -->
    <Viewbox Stretch="Uniform">
        <Grid
            Width="1200"
            Height="750"
            Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  TOP BAR  -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

                    <Button
                        x:Name="PreviousButton"
                        Width="110"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="PreviousMonth_Click"
                        Content="Previous" />

                    <Button
                        x:Name="TodayButton"
                        Width="100"
                        Height="40"
                        Margin="0,0,16,0"
                        Click="TodayButton_Click"
                        Content="Today" />

                    <TextBlock
                        x:Name="LanguageLabelTextBlock"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Text="Language" />

                    <ComboBox
                        x:Name="LanguageComboBox"
                        Width="150"
                        Height="34"
                        Margin="0,0,16,0"
                        SelectionChanged="LanguageComboBox_SelectionChanged" />

                    <Button
                        x:Name="GenerateJsonButton"
                        Width="140"
                        Height="40"
                        Click="GenerateJsonButton_Click"
                        Content="Generate JSON" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

                    <TextBlock
                        x:Name="MonthLabelTextBlock"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Text="Month" />

                    <ComboBox
                        x:Name="MonthComboBox"
                        Width="170"
                        Height="34"
                        Margin="0,0,14,0"
                        SelectionChanged="MonthComboBox_SelectionChanged" />

                    <TextBlock
                        x:Name="YearLabelTextBlock"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Text="Year" />

                    <ComboBox
                        x:Name="YearComboBox"
                        Width="110"
                        Height="34"
                        Margin="0,0,14,0"
                        SelectionChanged="YearComboBox_SelectionChanged" />

                    <Button
                        x:Name="NextButton"
                        Width="110"
                        Height="40"
                        Click="NextMonth_Click"
                        Content="Next" />
                </StackPanel>
            </Grid>

            <!--  TITLE  -->
            <TextBlock
                x:Name="BsDateText"
                Grid.Row="1"
                Margin="0,6,0,10"
                HorizontalAlignment="Center"
                FontSize="34"
                FontWeight="Bold" />

            <!--  SUBTITLE  -->
            <Border
                Grid.Row="2"
                Margin="0,0,0,18"
                Padding="18"
                Background="#FAFBFD"
                BorderBrush="#D9E2F0"
                BorderThickness="1"
                CornerRadius="12">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            Foreground="#4A5670"
                            Text="Selected Date (BS)" />
                        <TextBlock
                            x:Name="SelectedBsDateText"
                            Margin="0,0,0,2"
                            FontSize="18"
                            FontWeight="SemiBold" />
                        <TextBlock
                            x:Name="SelectedBsDayText"
                            FontSize="14"
                            Foreground="#4A5670" />
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Width="1"
                        Margin="20,0"
                        Background="#D9E2F0" />

                    <StackPanel Grid.Column="2">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            Foreground="#4A5670"
                            Text="Corresponding Date (AD)" />
                        <TextBlock
                            x:Name="SelectedAdDateText"
                            Margin="0,0,0,2"
                            FontSize="18"
                            FontWeight="SemiBold" />
                        <TextBlock
                            x:Name="SelectedAdDayText"
                            FontSize="14"
                            Foreground="#4A5670" />
                    </StackPanel>

                    <Border
                        Grid.Column="3"
                        Width="1"
                        Margin="20,0"
                        Background="#D9E2F0" />

                    <StackPanel Grid.Column="4" MinWidth="120">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            Foreground="#4A5670"
                            Text="Total Days" />
                        <TextBlock
                            x:Name="TotalDaysInfoText"
                            FontSize="18"
                            FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  WEEK HEADERS  -->
            <UniformGrid
                Grid.Row="3"
                Margin="0,0,0,10"
                Columns="7">
                <TextBlock
                    x:Name="SunHeader"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Sun" />

                <TextBlock
                    x:Name="MonHeader"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Mon" />

                <TextBlock
                    x:Name="TueHeader"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Tue" />

                <TextBlock
                    x:Name="WedHeader"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Wed" />

                <TextBlock
                    x:Name="ThuHeader"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Thu" />

                <TextBlock
                    x:Name="FriHeader"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Fri" />

                <TextBlock
                    x:Name="SatHeader"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="Red"
                    Text="Sat" />
            </UniformGrid>

            <!--  CALENDAR  -->
            <ItemsControl x:Name="CalendarGrid" Grid.Row="4">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>


                        <Border
                            Margin="0.5"
                            Padding="8"
                            Cursor="Hand"
                            MouseLeftButtonUp="CalendarDayBorder_Click">

                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="White" />
                                    <Setter Property="BorderBrush" Value="#D0D0D0" />
                                    <Setter Property="BorderThickness" Value="1" />

                                    <Style.Triggers>
                                        <!--  Today only  -->
                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                            <Setter Property="BorderBrush" Value="#1E90FF" />
                                            <Setter Property="BorderThickness" Value="1.5" />
                                        </DataTrigger>

                                        <!--  Selected only  -->
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="#EAF3FF" />
                                        </DataTrigger>

                                        <!--  Today + Selected  -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsToday}" Value="True" />
                                                <Condition Binding="{Binding IsSelected}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#DCEEFF" />
                                            <Setter Property="BorderBrush" Value="#1E90FF" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>   
                                </Style>
                            </Border.Style>

                            <Grid>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="26"
                                    FontWeight="Bold"
                                    Text="{Binding Text}">

                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Black" />

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                    <Setter Property="Foreground" Value="LightGray" />
                                                </DataTrigger>

                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsCurrentMonth}" Value="True" />
                                                        <Condition Binding="{Binding DayOfWeekIndex}" Value="6" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Foreground" Value="Red" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>

                                </TextBlock>
                            </Grid>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Grid>
    </Viewbox>
</Window>