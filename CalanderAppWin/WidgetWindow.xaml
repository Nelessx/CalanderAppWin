<Window
    x:Class="NepaliCalendar.App.WidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Nepali Calendar Widget"
    Width="300"
    Height="450"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Border
        x:Name="RootBorder"
        Padding="10"
        Background="#F6F9FF"
        BorderBrush="#E3EBF7"
        BorderThickness="1"
        CornerRadius="22"
        MouseLeftButtonDown="RootBorder_MouseLeftButtonDown"
        MouseLeftButtonUp="RootBorder_MouseLeftButtonUp"
        MouseMove="RootBorder_MouseMove">

        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Click="OpenAppMenuItem_Click" Header="Open App" />
                <Separator Style="{StaticResource ModernSeparatorStyle}" />
                <MenuItem Header="Widget Size">
                    <MenuItem Click="SwitchToSmallMenuItem_Click" Header="Small" />
                    <MenuItem Click="SwitchToMediumMenuItem_Click" Header="Medium" />
                    <MenuItem Click="SwitchToLargeMenuItem_Click" Header="Large" />
                </MenuItem>
                <Separator Style="{StaticResource ModernSeparatorStyle}" />
                <MenuItem Click="CloseMenuItem_Click" Header="Close Widget" />
            </ContextMenu>
        </Border.ContextMenu>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="60" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Width="36"
                    Height="36"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="#EAF3FF"
                    BorderBrush="#CFE0FF"
                    BorderThickness="1"
                    CornerRadius="11">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="#1E6BFF"
                        Text="BS" />
                </Border>

                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#172033"
                    Text="Nepali Calendar"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis" />

                <Border
                    Grid.Column="2"
                    Width="36"
                    Height="36"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0" />
            </Grid>

            <!--  Top date section  -->
            <StackPanel
                Grid.Row="1"
                Margin="0,0,0,6"
                HorizontalAlignment="Center">

                <TextBlock
                    x:Name="LargeBsMonthYearText"
                    Margin="0,0,0,-4"
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="#2B6FEA"
                    TextAlignment="Center" />

                <TextBlock
                    x:Name="LargeDayText"
                    Margin="0,-10,0,-10"
                    HorizontalAlignment="Center"
                    FontSize="58"
                    FontWeight="Bold"
                    Foreground="#0B1B45"
                    TextAlignment="Center" />

                <TextBlock
                    x:Name="LargeWeekdayText"
                    Margin="0,0,0,-1"
                    HorizontalAlignment="Center"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="#0B1B45"
                    TextAlignment="Center" />

                <TextBlock
                    x:Name="LargeAdDateText"
                    HorizontalAlignment="Center"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="#7A8FC0"
                    TextAlignment="Center" />
            </StackPanel>

            <!--  Divider  -->
            <Border
                Grid.Row="2"
                Height="1"
                Margin="0,0,0,6"
                Background="#E7EEF8" />

            <!--  Month nav  -->
            <Grid Grid.Row="3" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="PreviousMonthButton"
                    Grid.Column="0"
                    Width="26"
                    Height="26"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="PreviousMonthButton_Click"
                    Content="‹"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="#0B1B45" />

                <TextBlock
                    x:Name="CalendarMonthYearText"
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#0B1B45"
                    TextAlignment="Center" />

                <Button
                    x:Name="NextMonthButton"
                    Grid.Column="2"
                    Width="26"
                    Height="26"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="NextMonthButton_Click"
                    Content="›"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="#0B1B45" />
            </Grid>

            <!--  Calendar  -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Week headers  -->
                <ItemsControl
                    x:Name="WeekHeaderItemsControl"
                    Grid.Row="0"
                    Margin="0,0,0,2">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="#7A8AA6"
                                Text="{Binding}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="Sat">
                                                <Setter Property="Foreground" Value="#D92D20" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="शनि">
                                                <Setter Property="Foreground" Value="#D92D20" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--  Days  -->
                <ItemsControl x:Name="WidgetCalendarGrid" Grid.Row="1">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="34" Height="34">

                                <Border
                                    Width="28"
                                    Height="28"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    CornerRadius="14">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F7F7F5" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="Background" Value="#BFDDF8" />
                                                    <Setter Property="BorderBrush" Value="#5FA8F5" />
                                                    <Setter Property="BorderThickness" Value="1.5" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                    <Setter Property="Background" Value="#F7F7F5" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Text="{Binding Text}">

                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#0B1B45" />

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                    <Setter Property="Foreground" Value="#C2CAD8" />
                                                </DataTrigger>

                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsCurrentMonth}" Value="True" />
                                                        <Condition Binding="{Binding DayOfWeekIndex}" Value="6" />
                                                        <Condition Binding="{Binding IsToday}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Foreground" Value="#D92D20" />
                                                </MultiDataTrigger>

                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Border>
</Window>